---
// Product.astro
// Section id: #product
// JS binds to: #product-hero, #product-hero-inner, #product-hero-caption,
// #product-hero-title-wrapper, #product-hero-title, #product-hero-options,
// .product-hero-option-item [data-id], #product-details, #product-details-inner,
// #product-details-main, #product-details-title-wrapper, #product-details-desc-wrapper,
// #product-details-extra, .product-details-extra-item, #product-compare.
// All ids, classes, and data-* attributes are preserved verbatim.
---

<div id="product" class="section">
  <div class="section__inner o-container">

    <!-- Product selector hero -->
    <div id="product-hero">
      <div id="product-hero-inner">
        <h4 id="product-hero-caption">Pick a project</h4>
        <div id="product-hero-title-wrapper">
          <svg id="product-hero-title" viewBox="0 0 809 174">
            <use href="#logo-tmpl"></use>
          </svg>
        </div>
        <div id="product-hero-options">
          <button data-id="0" id="product-hero-option-oryzo"
            class="product-hero-option-item btn is-large is-dark is-active is-flipper">Sentiment Visualiser</button>
          <button data-id="1" id="product-hero-option-oryzo-pro"
            class="product-hero-option-item btn is-large is-dark is-flipper">E-Commerce Platform</button>
          <button data-id="2" id="product-hero-option-oryzo-pro-max"
            class="product-hero-option-item btn is-large is-dark is-flipper">MCP Agent Server</button>
        </div>
      </div>
    </div>

    <!-- Product details panel - JS swaps visible span/div on button click -->
    <div id="product-details">
      <div id="product-details-inner">
        <div id="product-details-main">

          <!-- Title spans - one per variant, JS shows the active one -->
          <h4 id="product-details-title-wrapper">
            <span>Sentiment Visualiser</span>
            <span>E-Commerce Platform</span>
            <span>MCP Agent Server</span>
          </h4>

          <!-- Description divs - one per variant -->
          <div id="product-details-desc-wrapper" class="body2">
            <div>Financial sentiment &amp; market event visualiser. Three-microservice architecture on AWS,
              star-map UI for sentiment vs price. Won the Optiver industry prize at UNSW 3011 Capstone, 2026.</div>
            <div>Full-stack e-commerce storefront with React, Node.js and PostgreSQL. 25+ REST endpoints,
              93% test coverage, deployed on Vercel. Earned a letter of recommendation from the UNSW Director of Studies.</div>
            <div>An MCP server that exposes every API endpoint as an AI-callable tool, so a Claude/OpenAI agent
              can run the storefront end-to-end via natural language. Cursor and LLM workflows out of the box.</div>
          </div>
        </div>

        <!-- Hidden SVG symbol for the double-circle bullet icon -->
        <svg style="display: none;">
          <symbol id="product-double-circles">
            <circle cx="10" cy="10" r="9.5" fill="#FFEDD7" fill-opacity=".1" stroke="#FFEDD6"
              stroke-dasharray="2 2"></circle>
            <circle cx="9.999" cy="10.002" r="5.499" stroke="#FFEDD6" stroke-dasharray="2 2"></circle>
          </symbol>
        </svg>

        <!-- Extra bullet rows - three divs per row (one per variant) -->
        <div id="product-details-extra" class="body2">
          <div class="product-details-extra-item">
            <svg viewBox="0 0 20 20"><use href="#product-double-circles"></use></svg>
            <div>Python · AWS Lambda · API Gateway · Docker</div>
            <div>React · Node.js · PostgreSQL · Vercel</div>
            <div>TypeScript · Node.js · Model Context Protocol</div>
          </div>
          <div class="product-details-extra-item">
            <svg viewBox="0 0 20 20"><use href="#product-double-circles"></use></svg>
            <div>3-microservice cloud architecture</div>
            <div>25+ REST endpoints, 93% test coverage</div>
            <div>Every endpoint exposed as an AI-callable tool</div>
          </div>
          <div class="product-details-extra-item">
            <svg viewBox="0 0 20 20"><use href="#product-double-circles"></use></svg>
            <div>Won Optiver industry prize</div>
            <div>Director of Studies recommendation</div>
            <div>Live LLM workflows in Cursor &amp; Claude</div>
          </div>
        </div>

      </div>
    </div>

    <!-- Comparison table -->
    <table id="product-compare" class="sub2">
      <tr>
        <th><h5>2026</h5><h4>Sentiment Visualiser</h4></th>
        <th><h5>2026</h5><h4>E-Commerce Platform</h4></th>
        <th><h5>2026</h5><h4>MCP Agent Server</h4></th>
      </tr>
      <tr class="body3">
        <td><span>Three microservices, one star map. Sentiment in, signal out.</span></td>
        <td><span>A storefront engineered like real product infra.</span></td>
        <td><span>An LLM-ready control plane sitting on top of your API.</span></td>
      </tr>
      <tr>
        <td><div>Stack:</div><span>Python · AWS · Docker</span></td>
        <td><div>Stack:</div><span>React · Node · PostgreSQL</span></td>
        <td><div>Stack:</div><span>TS · Node · MCP</span></td>
      </tr>
      <tr>
        <td><div>Surface:</div><span>Interactive web visualiser</span></td>
        <td><div>Surface:</div><span>Full e-commerce frontend</span></td>
        <td><div>Surface:</div><span>Tool-calling for AI agents</span></td>
      </tr>
      <tr>
        <td><div>Backend:</div><span>3 microservices on AWS</span></td>
        <td><div>Backend:</div><span>25+ REST endpoints</span></td>
        <td><div>Backend:</div><span>Wraps every endpoint as a tool</span></td>
      </tr>
      <tr>
        <td><div>Tests:</div><span>Unit + integration</span></td>
        <td><div>Tests:</div><span>93% coverage</span></td>
        <td><div>Tests:</div><span>Live LLM eval workflow</span></td>
      </tr>
      <tr>
        <td><div>Recognition:</div><span>Optiver Industry Prize</span></td>
        <td><div>Recognition:</div><span>Director of Studies letter</span></td>
        <td><div>Recognition:</div><span>Powers the agent demos</span></td>
      </tr>
      <tr>
        <td><div>Year:</div><span>Feb–Apr 2026</span></td>
        <td><div>Year:</div><span>Mar–Apr 2026</span></td>
        <td><div>Year:</div><span>Mar–Apr 2026</span></td>
      </tr>
      <tr>
        <td><div>Repo:</div><span>github.com/Hardik-V/3011_Bravo</span></td>
        <td><div>Repo:</div><span>github.com/nloudev/H14B_CoolCoolCool</span></td>
        <td><div>Repo:</div><span>Inside the e-commerce repo</span></td>
      </tr>
    </table>

  </div>
</div>
