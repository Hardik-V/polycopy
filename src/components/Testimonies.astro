---
// Testimonies.astro
// Section id: #testimonies
// JS binds to: #testimonies-hero, #testimonies-hero-title, #testimonies-hero-desc,
// #testimonies-table, #testimonies-table-header, #testimonies-table-list,
// .testimonies-table-item, .testimonies-table-item-content,
// .testimonies-table-item-image-wrapper, .testimonies-table-rating.
// Star SVG symbols (#star, #star-half) must be in the same document as their
// <use> references - they are scoped inside this section's hidden <svg>.
// All ids, classes, and data-* attributes are preserved verbatim.
---

<div id="testimonies" class="section">
  <div class="section__inner o-container">

    <!-- Hero heading -->
    <div id="testimonies-hero">
      <h2 id="testimonies-hero-title">Teammates, tutors and judges have nice things to say.</h2>
      <div id="testimonies-hero-desc" class="body1">
        Don't take my word for it. Here's a snapshot of recommendations and feedback from people I've built alongside.
      </div>
    </div>

    <div id="testimonies-table">

      <!-- Hidden SVG sprite for star icons -->
      <svg style="display: none;">
        <symbol id="star-half">
          <path
            d="M6.9907.9943c.1811-.464.8376-.464,1.0187,0l1.5153,3.8817c.0777.1991.2643.3347.4776.347l4.1599.2415c.4972.0289.7001.6533.3148.9689l-3.2234,2.6405c-.1654.1355-.2366.3548-.1825.5616l1.0558,4.0309c.1262.4818-.405.8677-.8242.5988l-3.5074-2.2497c-.1799-.1154-.4105-.1154-.5904,0l-3.5074,2.2497c-.4192.2689-.9504-.117-.8242-.5988l1.0558-4.0309c.0542-.2068-.0171-.4261-.1825-.5616L.523,6.4334c-.3853-.3156-.1824-.94.3148-.9689l4.1599-.2415c.2134-.0124.4-.1479.4777-.347l1.5152-3.8817Z"
            style="fill:#ffedd6; opacity:.5;"></path>
          <path
            d="M7.4709.6548c-.199.0107-.3942.1188-.4803.3395l-1.5152,3.8817c-.0778.1991-.2643.3347-.4777.347l-4.1599.2415c-.4972.0289-.7001.6533-.3148.9689l3.2234,2.6406c.1653.1355.2366.3548.1824.5616l-1.0557,4.0309c-.1262.4818.4049.8677.8242.5988l3.5074-2.2497c.0811-.052.1738-.0729.2662-.078V.6548Z"
            style="fill:#ffedd6;"></path>
        </symbol>
        <symbol id="star">
          <path
            d="M6.9604.9533c.1811-.464.8376-.464,1.0187,0l1.5153,3.8817c.0777.1991.2643.3347.4776.347l4.1599.2415c.4972.0289.7001.6533.3148.9689l-3.2234,2.6405c-.1654.1355-.2366.3548-.1825.5616l1.0558,4.0309c.1262.4818-.405.8677-.8242.5988l-3.5074-2.2497c-.1799-.1154-.4105-.1154-.5904,0l-3.5074,2.2497c-.4192.2689-.9504-.117-.8242-.5988l1.0558-4.0309c.0542-.2068-.0171-.4261-.1825-.5616L.4928,6.3925c-.3853-.3156-.1824-.94.3148-.9689l4.1599-.2415c.2134-.0124.4-.1479.4777-.347l1.5152-3.8817Z"
            style="fill: #ffedd7;"></path>
        </symbol>
      </svg>

      <!-- Table header -->
      <div id="testimonies-table-header" class="sub2">
        <div id="testimonies-table-header-title">Recommendations</div>
        <div id="testimonies-table-header-center">
          <div id="testimonies-table-header-reviews">Verified feedback [ 12 ]</div>
          <div class="testimonies-table-rating">
            <svg width="96" height="15">
              <use href="#star"></use>
              <use href="#star" x="19"></use>
              <use href="#star" x="38"></use>
              <use href="#star" x="57"></use>
              <use href="#star" x="76"></use>
            </svg>
            <div class="testimonies-table-rating-text">[ 4.9/5 ]</div>
          </div>
        </div>
        <div id="testimonies-table-header-right">Hardik in the wild</div>
      </div>

      <div class="o-dashline"></div>

      <!-- Review list -->
      <div id="testimonies-table-list">

        <!-- Review 1 -->
        <div class="testimonies-table-item">
          <div class="testimonies-table-item-content">
            <div class="testimonies-table-rating">
              <svg width="96" height="15">
                <use href="#star"></use><use href="#star" x="19"></use><use href="#star" x="38"></use>
                <use href="#star" x="57"></use><use href="#star" x="76"></use>
              </svg>
              <div class="testimonies-table-rating-text sub2">[ 5/5 ]</div>
            </div>
            <div class="testimonies-table-item-content-title quote">
              "His project won the <span>Optiver industry prize</span><br />for excellence. The architecture<br />and execution were standout."
            </div>
            <div class="testimonies-table-item-content-author sub2">
              <div class="testimonies-table-item-content-author-name">Optiver Industry Panel</div>
              <div class="testimonies-table-item-content-author-desc">Judges, 3011 Capstone (2026)</div>
            </div>
          </div>
          <div class="testimonies-table-item-image-wrapper">
            <picture>
              <source media="(min-width:768px)" srcset="/images/testimonies/astronut.webp" width="640" height="480" />
              <img src="/images/testimonies/astronut_MOBILE.webp" width="64" height="64" loading="lazy"
                decoding="async" />
            </picture>
          </div>
        </div>

        <div class="o-dashline"></div>

        <!-- Review 2 -->
        <div class="testimonies-table-item">
          <div class="testimonies-table-item-content">
            <div class="testimonies-table-rating">
              <svg width="96" height="15">
                <use href="#star"></use><use href="#star" x="19"></use><use href="#star" x="38"></use>
                <use href="#star" x="57"></use><use href="#star-half" x="76"></use>
              </svg>
              <div class="testimonies-table-rating-text sub2">[ 4.5/5 ]</div>
            </div>
            <div class="testimonies-table-item-content-title quote">
              "Hardik built an MCP server, 25+ REST endpoints,<br />and 93% test coverage. He's the rare student<br />who ships things that belong <span>in production</span>."
            </div>
            <div class="testimonies-table-item-content-author sub2">
              <div class="testimonies-table-item-content-author-name">UNSW Director of Studies</div>
              <div class="testimonies-table-item-content-author-desc">Letter of recommendation, 2026</div>
            </div>
          </div>
          <div class="testimonies-table-item-image-wrapper">
            <picture>
              <source media="(min-width:768px)" srcset="/images/testimonies/pirate_king.webp" width="640"
                height="480" />
              <img src="/images/testimonies/pirate_king_MOBILE.webp" width="64" height="64" loading="lazy"
                decoding="async" />
            </picture>
          </div>
        </div>

        <div class="o-dashline"></div>

        <!-- Review 3 -->
        <div class="testimonies-table-item">
          <div class="testimonies-table-item-content">
            <div class="testimonies-table-rating">
              <svg width="96" height="15">
                <use href="#star"></use><use href="#star" x="19"></use><use href="#star" x="38"></use>
                <use href="#star" x="57"></use><use href="#star" x="76"></use>
              </svg>
              <div class="testimonies-table-rating-text sub2">[ 5/5 ]</div>
            </div>
            <div class="testimonies-table-item-content-title quote">
              "Calm, kind, and <span>weirdly fast</span> at debugging.<br />Carries every team meeting<br />with actual answers."
            </div>
            <div class="testimonies-table-item-content-author sub2">
              <div class="testimonies-table-item-content-author-name">Nathan L.</div>
              <div class="testimonies-table-item-content-author-desc">E-commerce capstone teammate</div>
            </div>
          </div>
          <div class="testimonies-table-item-image-wrapper">
            <picture>
              <source media="(min-width:768px)" srcset="/images/testimonies/youtuber.webp" width="640" height="480" />
              <img src="/images/testimonies/youtuber_MOBILE.webp" width="64" height="64" loading="lazy"
                decoding="async" />
            </picture>
          </div>
        </div>

        <div class="o-dashline"></div>

        <!-- Review 4 -->
        <div class="testimonies-table-item">
          <div class="testimonies-table-item-content">
            <div class="testimonies-table-rating">
              <svg width="96" height="15">
                <use href="#star"></use><use href="#star" x="19"></use><use href="#star" x="38"></use>
                <use href="#star" x="57"></use><use href="#star" x="76"></use>
              </svg>
              <div class="testimonies-table-rating-text sub2">[ 5/5 ]</div>
            </div>
            <div class="testimonies-table-item-content-title quote">
              "Asked him to explain calculus. Came out understanding <span>three units</span> better."
            </div>
            <div class="testimonies-table-item-content-author sub2">
              <div class="testimonies-table-item-content-author-name">Maths & Sciences Tutee</div>
              <div class="testimonies-table-item-content-author-desc">Year 12, HSC student</div>
            </div>
          </div>
          <div class="testimonies-table-item-image-wrapper">
            <picture>
              <source media="(min-width:768px)" srcset="/images/testimonies/attention.webp" width="640" height="480" />
              <img src="/images/testimonies/attention_MOBILE.webp" width="64" height="64" loading="lazy"
                decoding="async" />
            </picture>
          </div>
        </div>

        <div class="o-dashline"></div>

        <!-- Review 5 -->
        <div class="testimonies-table-item">
          <div class="testimonies-table-item-content">
            <div class="testimonies-table-rating">
              <svg width="96" height="15">
                <use href="#star"></use><use href="#star" x="19"></use><use href="#star" x="38"></use>
                <use href="#star" x="57"></use><use href="#star" x="76"></use>
              </svg>
              <div class="testimonies-table-rating-text sub2">[ 5/5 ]</div>
            </div>
            <div class="testimonies-table-item-content-title quote">
              "Grew our social engagement by ~60% as PR Director.<br />Now I trust him with <span>anything that has a deadline</span>."
            </div>
            <div class="testimonies-table-item-content-author sub2">
              <div class="testimonies-table-item-content-author-name">UNSW Hindu Society</div>
              <div class="testimonies-table-item-content-author-desc">Exec committee, 2025–present</div>
            </div>
          </div>
          <div class="testimonies-table-item-image-wrapper">
            <picture>
              <source media="(min-width:768px)" srcset="/images/testimonies/flat_earth.webp" width="640"
                height="480" />
              <img src="/images/testimonies/flat_earth_MOBILE.webp" width="64" height="64" loading="lazy"
                decoding="async" />
            </picture>
          </div>
        </div>

        <div class="o-dashline"></div>

      </div>
      <!-- end #testimonies-table-list -->

    </div>
    <!-- end #testimonies-table -->

  </div>
</div>
