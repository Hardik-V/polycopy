---
// Features.astro
// Section id: #features
// JS binds to: #features-items, .features-item [data-id], #features-item-elevate,
// #features-item-temperature, #features-item-curve, #features-circular-logo-wrapper,
// #features-circular-logo, #features-curve-canvas, #features-temperature-slider,
// #features-temperature-slider__bar, #features-extra-wrapper.
// All ids, classes, and data-* attributes are preserved verbatim.
---

<div id="features" class="section">
  <div class="section__inner o-container">

    <div id="features-items">

      <!-- Feature 1: Elevate -->
      <div id="features-item-elevate" class="features-item" data-id="elevate">
        <div class="features-item-top">
          <div class="features-item-icon">
            <svg viewBox="0 0 64 64" fill="none">
              <circle cx="32" cy="32" r="32" fill="#ffedd6" opacity=".2"></circle>
              <path fill="#ffedd6" stroke="#ffedd6" stroke-width="1.036"
                d="m24.019 26.764 7.917-10.11a.088.088 0 0 1 .139 0l7.917 10.11h-4.698v12.739h-6.577V26.764z">
              </path>
              <path stroke="#ffedd6" stroke-linecap="square" stroke-width="1.147" d="M28.769 42.148h6.378"
                opacity=".8"></path>
              <path stroke="#ffedd6" stroke-linecap="square" stroke-width="1.147" d="M28.769 44.797h6.378"
                opacity=".6"></path>
              <path stroke="#ffedd6" stroke-linecap="square" stroke-width="1.147" d="M28.769 47.436h6.378"
                opacity=".4"></path>
              <path stroke="#ffedd6" stroke-width=".723"
                d="M32.007 29.783c3.558 0 6.763.611 9.064 1.586 1.15.487 2.06 1.058 2.675 1.673.613.615.917 1.254.917 1.891s-.304 1.276-.917 1.89c-.616.615-1.524 1.186-2.675 1.674-2.301.974-5.506 1.586-9.064 1.586s-6.762-.612-9.063-1.586c-1.151-.488-2.06-1.059-2.675-1.674-.614-.614-.917-1.253-.917-1.89s.303-1.276.917-1.89c.615-.616 1.524-1.187 2.675-1.674 2.3-.975 5.505-1.586 9.063-1.586Z">
              </path>
            </svg>
          </div>
          <div class="features-item-tagline sub1">Rise above the boilerplate</div>
        </div>
        <div class="features-item-desc body2">
          Star-map visualisations, three-microservice AWS stacks, MCP servers wired into LLM agents.
          The kind of work that takes a brief and lifts it into something that actually wins prizes.
        </div>
        <div class="o-dashline"></div>
        <h3 class="features-item-title">Elevate the product experience</h3>
      </div>

      <!-- Feature 2: Temperature -->
      <div id="features-item-temperature" class="features-item" data-class="temperature">
        <div class="features-item-top">
          <div class="features-item-icon">
            <svg viewBox="0 0 54 54" fill="none">
              <circle cx="27" cy="27" r="27" fill="#ffedd6" opacity=".2"></circle>
              <path fill="#ffedd6"
                d="M20.544 21.697a.468.468 0 0 1 .767.36v1h-.004v12.706a5.686 5.686 0 0 0 11.37 0v-1.939h.8v1.939a6.485 6.485 0 0 1-12.971 0V22.96l-.304.355-.304-.26-.303-.26.893-1.043zm6.448-6.845a3.375 3.375 0 0 1 3.375 3.375v17.55a3.375 3.375 0 0 1-6.75 0v-17.55a3.375 3.375 0 0 1 3.375-3.375M24.29 34.764h2.7a.338.338 0 0 0 0-.676h-2.7zm0-2.024h1.35a.338.338 0 0 0 0-.675h-1.35zm2.703-20.992a6.486 6.486 0 0 1 6.485 6.486v12.803l.31-.361.304.26.303.26-.893 1.043-.057.056a.468.468 0 0 1-.766-.36v-13.7a5.686 5.686 0 0 0-11.371 0V20.2h-.801v-1.967a6.487 6.487 0 0 1 6.486-6.486M24.29 30.717h2.7a.338.338 0 0 0 0-.676h-2.7zm0-2.027h1.35a.338.338 0 0 0 0-.676h-1.35zm0-2.024h2.7a.337.337 0 0 0 0-.676h-2.7zm0-2.027h1.35a.338.338 0 0 0 0-.676h-1.35zm0-2.024h2.7a.337.337 0 0 0 0-.675h-2.7zm0-2.023h1.35a.338.338 0 0 0 0-.676h-1.35z">
              </path>
            </svg>
          </div>
          <div class="features-item-tagline sub1">Handles extremes with ease</div>
        </div>
        <div class="features-item-desc body2">
          From cold-start Lambdas to 25+ live REST endpoints under load, the systems I build stay calm
          under pressure. Your sprint board already tapped out three tickets ago.
        </div>
        <div class="o-dashline"></div>
        <h3 class="features-item-title">Production-grade stability</h3>
      </div>

      <!-- Feature 3: Curve / Circularity -->
      <div id="features-item-curve" class="features-item" data-class="curve">
        <div class="features-item-top">
          <div class="features-item-icon">
            <svg viewBox="0 0 54 54" fill="none">
              <circle cx="27" cy="27" r="27" fill="#ffedd6" opacity=".2"></circle>
              <circle cx="27.001" cy="26.997" r="13.818" stroke="#ffedd6" stroke-width=".789"></circle>
              <path fill="#ffedd6"
                d="M42 25.734v2.324h-2.324v-2.324zM14.328 25.734v2.324h-2.323v-2.324zM26.992 17.754a9.25 9.25 0 1 1-.002 18.5 9.25 9.25 0 0 1 .002-18.5m.532 10.336 1.632 1.632.558-.558-1.632-1.632zm-3.245 1.058.558.557 1.633-1.632-.559-.558zm.024-4.28 1.632 1.633.558-.559-1.633-1.631zm3.198 1.058.558.557 1.631-1.631-.557-.558zM25.828 11.961h2.324v2.324h-2.324zM25.828 39.711h2.324v2.324h-2.324z">
              </path>
            </svg>
          </div>
          <div class="features-item-tagline sub1">Tested. Seriously.</div>
        </div>
        <div class="features-item-desc body2">
          93% test coverage. Recalibrated CI pipelines. Documented APIs with disturbing levels of attention to detail,
          just because shipping broken software isn't a vibe.
        </div>
        <div class="o-dashline"></div>
        <h3 class="features-item-title">Now 93% Better Tested</h3>
      </div>

    </div>
    <!-- end #features-items -->

    <!-- Circular logo - JS rotates this on scroll -->
    <div id="features-circular-logo-wrapper">
      <svg id="features-circular-logo">
        <use href="#logo-tmpl"></use>
      </svg>
    </div>

    <!-- WebGL curve canvas -->
    <canvas id="features-curve-canvas"></canvas>

    <!-- Temperature slider - JS drives the bar position -->
    <div id="features-temperature-slider" class="sub2">
      <div id="features-temperature-slider__text-container">
        <div class="features-temperature-slider__text">Creative<br />T = 10</div>
        <div class="features-temperature-slider__text">Balanced<br />T = 1</div>
        <div class="features-temperature-slider__text">Deterministic<br />T = 0.1</div>
      </div>
      <div id="features-temperature-slider__bar-wrapper">
        <div id="features-temperature-slider__bar"></div>
      </div>
    </div>

    <!-- Equation footnotes (desktop only) -->
    <div id="features-extra-wrapper" class="body3 desktop-only">

      <div class="features-extra-item">
        <div class="features-extra-item__footnote">Constant lift via geometry</div>
        <div class="features-extra-item__equation">
          <svg viewBox="0 0 137 41">
            <path fill="#FFEDD6"
              d="M120.221 17.424v-1.776c1.696-.992 3.024-1.984 3.984-2.976s1.696-2.176 2.208-3.552h1.392v6.048h6.432v2.256h-6.432v14.592c0 1.12.048 2.064.144 2.832.128.768.32 1.392.576 1.872.256.448.592.768 1.008.96.416.192.944.288 1.584.288.8 0 1.472-.16 2.016-.48.576-.352 1.136-.928 1.68-1.728l1.2.912c-.448 1.184-1.232 2.096-2.352 2.736-1.088.608-2.448.912-4.08.912-2.112 0-3.728-.496-4.848-1.488-1.088-1.024-1.632-2.48-1.632-4.368v-17.04h-2.88ZM79.452 24.96v-3.744c1.536-1.68 3.456-2.544 5.76-2.544 1.824 0 3.408.288 6.336 1.536 2.304 1.008 3.648 1.296 4.992 1.296 1.872 0 3.984-1.248 5.52-2.832v3.696c-1.536 1.68-3.456 2.592-5.76 2.592-1.824 0-3.456-.288-6.336-1.536-2.304-1.008-3.648-1.296-5.04-1.296-1.776 0-3.936 1.248-5.472 2.832Zm0 9.456v-3.744c1.536-1.68 3.456-2.544 5.76-2.544 1.824 0 3.408.288 6.336 1.536 2.304 1.008 3.648 1.296 4.992 1.296 1.872 0 3.984-1.248 5.52-2.832v3.696c-1.536 1.68-3.456 2.592-5.76 2.592-1.824 0-3.456-.288-6.336-1.536-2.304-1.008-3.648-1.296-5.04-1.296-1.776 0-3.936 1.248-5.472 2.832ZM40.16 32.208c0 1.312.032 2.352.096 3.12.064.768.224 1.36.48 1.776.288.384.688.64 1.2.768s1.232.224 2.16.288v1.68H31.328v-1.68c.928-.064 1.664-.16 2.208-.288.544-.128.96-.384 1.248-.768.288-.384.464-.928.528-1.632.096-.736.144-1.712.144-2.928V12.432c0-1.888-.032-3.392-.096-4.512-.032-1.12-.112-1.968-.24-2.544-.064-.384-.176-.688-.336-.912a1.224 1.224 0 0 0-.624-.576c-.288-.16-.672-.272-1.152-.336a13.77 13.77 0 0 0-1.776-.096V1.824L40.064 0v18.288h.192a8.297 8.297 0 0 1 1.776-1.728 13.38 13.38 0 0 1 2.352-1.392 14.65 14.65 0 0 1 2.592-.912 11.446 11.446 0 0 1 2.688-.336c1.472 0 2.816.256 4.032.768 1.248.512 2.208 1.2 2.88 2.064.544.736.944 1.712 1.2 2.928.256 1.184.384 2.8.384 4.848v7.68c0 1.312.032 2.352.096 3.12.064.736.224 1.312.48 1.728.288.416.688.688 1.2.816s1.232.224 2.16.288v1.68h-12.72v-1.68c.896-.032 1.616-.112 2.16-.24.544-.16.944-.432 1.2-.816.288-.384.464-.928.528-1.632.096-.736.144-1.712.144-2.928v-6.048c0-3.584-.416-6.128-1.248-7.632-.832-1.536-2.224-2.304-4.176-2.304-1.504 0-2.88.384-4.128 1.152-1.216.768-2.176 1.824-2.88 3.168-.16.352-.304.688-.432 1.008a6.69 6.69 0 0 0-.24 1.008c-.064.384-.112.832-.144 1.344v7.968ZM0 39.84v-2.4L12.912 5.424H16.8L29.664 37.44v2.4H0Zm4.944-3.888h19.728l-8.016-20.928a340 340 0 0 0-.528-1.392c-.256-.672-.512-1.36-.768-2.064a72.23 72.23 0 0 0-.528-1.68c-.16.64-.352 1.296-.576 1.968-.192.64-.4 1.232-.624 1.776a85.934 85.934 0 0 0-.48 1.392L4.944 35.952Z">
            </path>
          </svg>
        </div>
      </div>

      <div class="features-extra-item">
        <div class="features-extra-item__footnote">THERMAL DIFFUSION MODEL (TDM)<br />A visualization, not a warranty
        </div>
        <div class="features-extra-item__equation">
          <svg viewBox="0 0 241 73">
