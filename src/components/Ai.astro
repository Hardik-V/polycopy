---
// AI.astro
// Section id: #ai
// JS binds to: #ai, #ai-pre, #ai-header, #ai-title, #ai-tagline,
// #ai-instruction, #ai-instruction-icon, #ai-instruction-text,
// #ai-desc, #ai-disclaimer-wrapper, #ai-disclaimer.
// The <sup>*</sup> and footnote must be preserved - JS reads inner text.
// Copy rewritten for a Financial Sentiment Visualiser (AWS / API Gateway theme).
---

<div id="ai" class="section">
  <div class="section__inner o-container">

    <!-- Pre-header - split spans are animated individually by the JS engine -->
    <div id="ai-pre">
      <h2>notgit  just <br>a developer.</h2>
      <div class="body1">
        <span>I don't just write code. </span>
        <span>I design agentic systems </span>
        <span>that let LLMs* </span>
        <span>do the heavy lifting.</span>
      </div>
    </div>

    <!-- Primary heading -->
    <div id="ai-header">
      <h1 id="ai-title">Powered by AI<sup>*</sup></h1>
      <h4 id="ai-tagline">MCP-1</h4>
    </div>

    <!-- Hover instruction (desktop only) - JS shows/hides based on pointer -->
    <div id="ai-instruction" class="sub2 desktop-only">
      <svg id="ai-instruction-icon">
        <use href="#hand-tmpl"></use>
      </svg>
      <div class="o-dashline"></div>
      <div id="ai-instruction-text">Try to hover the signal</div>
    </div>

    <!-- Animated descriptor lines - each <span> is staggered by JS -->
    <div id="ai-desc" class="sub1">
      <span>LLMs fill in the gaps.</span>
      <span> I built the MCP server.</span>
      <span> The agent shipped the feature.</span>
    </div>

    <!-- Footnote / disclaimer - <span> children are animated separately -->
    <div id="ai-disclaimer-wrapper">
      <div class="o-dashline"></div>
      <div id="ai-disclaimer" class="sub2">
        <span>* Model</span>
        <span> Context Protocol</span>
      </div>
    </div>

  </div>
</div>