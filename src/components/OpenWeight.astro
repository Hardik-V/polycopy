---
// OpenWeight.astro
// Section id: #open-weight
// JS binds to: #open-weight-header, #open-weight-tagline, #open-weight-title,
// #open-weight-btns-wrapper, .open-weight-article, .open-weight-cat,
// .open-weight-desc, #open-weight-bibtex.
// All ids, classes, and data-* attributes are preserved verbatim.
---

<div id="open-weight" class="section">
  <div class="section__inner body2">

    <div id="open-weight-header">
      <h5 id="open-weight-tagline" class="sub2">The featured open-source project</h5>

      <!-- ORYZO-1 title: logotype SVG + "1" numeral SVG -->
      <h2 id="open-weight-title">
        <svg viewBox="0 0 809 174">
          <use href="#logo-tmpl"></use>
        </svg>
        <svg viewBox="0 0 66 62">
          <path fill="currentColor"
            d="M65.132 0v61.077H52.22v-48.82h-.358l-13.986 8.768V9.573L52.994 0zM27.854 25.498v10.08H0v-10.08z">
          </path>
        </svg>
      </h2>

      <!-- Download / link buttons -->
      <div id="open-weight-btns-wrapper">
        <a href="https://github.com/Hardik-V/3011_Bravo#readme" target="_blank"
          class="btn is-dark is-flipper">
          <svg viewBox="0 0 15 20">
            <path
              d="M3 0h2.228c1.093 0 2.245.393 3.327.987 1.09.598 2.159 1.428 3.098 2.368.94.94 1.767 2.006 2.364 3.092.591 1.077.983 2.221.983 3.303v6.75a3 3 0 0 1-3 3H3a3 3 0 0 1-3-3V3a3 3 0 0 1 3-3Zm7.592 4.415a12.928 12.928 0 0 0-2.38-1.894c.025.156.038.316.038.479v2.25a1.5 1.5 0 0 0 1.5 1.5H12c.164 0 .325.013.481.038a12.956 12.956 0 0 0-1.889-2.373ZM4.5 10.5a.75.75 0 1 0 0 1.5h4a.75.75 0 1 0 0-1.5h-4Zm0 3a.75.75 0 1 0 0 1.5h6a.75.75 0 1 0 0-1.5h-6Z">
            </path>
          </svg>
          <span class="is-flipper-target">Write-up</span>
        </a>

        <a href="https://www.linkedin.com/in/v-hardik" target="_blank"
          class="btn is-dark is-flipper">
          <svg viewBox="0 0 18 20">
            <path
              d="M2.84.888C4.387.33 6.477 0 8.75 0c2.272 0 4.362.33 5.91.888.772.277 1.449.626 1.947 1.05.496.421.893.99.893 1.692l-.001.077.001.043v12.165c0 .772-.418 1.38-.965 1.823-.54.438-1.265.768-2.06 1.019-1.597.503-3.679.743-5.725.743s-4.128-.24-5.725-.743c-.795-.25-1.52-.581-2.06-1.019C.418 17.295 0 16.687 0 15.915V3.75l.001-.043L0 3.63c0-.702.397-1.27.893-1.692.498-.424 1.176-.773 1.947-1.05ZM1.5 5.976V9.5c0 .664.574 1.363 2.022 1.926 1.386.54 3.287.824 5.228.824 1.941 0 3.842-.285 5.228-.824C15.426 10.863 16 10.164 16 9.5V5.976a7.22 7.22 0 0 1-1.504.703c-1.605.556-3.694.821-5.746.821-2.052 0-4.141-.265-5.746-.821A7.22 7.22 0 0 1 1.5 5.976Z">
