            <path
              d="M17.206 3.783a2.664 2.664 0 0 1 .018-.356c.024-.23.063-.472.104-.736.024-.154.05-.316.073-.487.056-.397.12-.907.049-1.298-.034-.185-.133-.554-.49-.77-.39-.234-.79-.118-1.016-.013-.546.254-1.19.536-1.79.725-.3.094-.572.16-.8.188-.238.03-.382.016-.454-.005-.98-.29-2.042-.447-3.15-.447-.961 0-1.89.12-2.757.34-.394.1-.811.05-1.31-.115A10.72 10.72 0 0 1 4.629.373c-.182-.083-.374-.17-.582-.26-.285-.12-.65-.168-1.001.022-.314.17-.472.457-.553.662-.161.402-.2.93-.214 1.355-.008.255-.008.56-.01.83l-.001.452c-.001.137-.01.274-.023.41v.004C1.465 4.848 1 6.036 1 7.322c0 1.917 1.03 3.803 2.644 5.011.789.59 1.71 1.015 2.709 1.294a2.83 2.83 0 0 0-.352 1.327v.858H4.664c-.347 0-.801-.275-1.296-.817-.462-.506-.814-1.082-.976-1.348-.347-.572-.894-.894-1.55-.974a.75.75 0 0 0-.182 1.49c.243.03.363.12.45.263l.002.004c.166.272.58.956 1.148 1.576.535.587 1.375 1.306 2.404 1.306H6v1.438c0 .414.337.75.75.75h6.497a.75.75 0 0 0 .748-.75v-3.765c0-.492-.142-.983-.388-1.468.886-.275 1.708-.663 2.404-1.184 1.65-1.235 2.488-3.139 2.488-5.01 0-1.316-.485-2.527-1.294-3.54Z">
