---
// Sentiment.astro  (maps to the original #encryption section)
// JS binds to: #encryption, #encryption-main, #encryption-header,
// #encryption-tagline, #encryption-title, #encryption-desc,
// #encryption-field, .encryption-field-line, #encryption-field-input,
// #encryption-field-flip-btn, #encryption-field-flip-btn-inner,
// .is-flipper-target (both spans inside the button).
// All ids, classes, and data-* attributes are preserved verbatim.
---

<div id="encryption" class="section">
  <div class="section__inner o-container">
    <div id="encryption-main">

      <div id="encryption-header">
        <div id="encryption-tagline" class="sub1">Ideas in, working software out</div>
        <h2 id="encryption-title">Prompt to <br />production</h2>
        <div id="encryption-desc" class="body2">
          Type a brief. Flip. A working prototype appears, <br />because behind the scenes the agents are doing real work.
        </div>
      </div>

      <!-- Input field - four decorative line divs + the real <input> -->
      <div id="encryption-field">
        <div class="encryption-field-line"></div>
        <div class="encryption-field-line"></div>
        <div class="encryption-field-line"></div>
        <div class="encryption-field-line"></div>
        <input type="text" id="encryption-field-input" value="HARDIK" maxlength="10" />
      </div>

      <!-- Flip button - is-flipper + two is-flipper-target spans toggled by JS -->
      <button id="encryption-field-flip-btn" class="btn is-active is-flipper">
        <span id="encryption-field-flip-btn-inner">
          <span class="is-flipper-target">Send to agent</span>
          <span class="is-flipper-target">Get response</span>
        </span>
      </button>

    </div>
  </div>
</div>