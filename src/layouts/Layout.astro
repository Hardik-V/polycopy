---
// Layout.astro
// Provides the <html> + <head> shell only.
// The body structure is owned entirely by index.astro so the JS engine gets
// the exact DOM it expects without any extra wrapper divs.
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Hardik Verma · Software Engineer",
  description = "Hardik Verma. Software Engineer (UNSW). AI agents, cloud microservices, full-stack systems that hold up under load.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="no-js">
  <head>
    <title>{title}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content={description} />
    <meta name="author" content="Hardik Verma" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#000000" />

    <link rel="canonical" href="https://github.com/Hardik-V" />
    <base href="/" />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/meta/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/meta/favicon.svg" />
    <link rel="shortcut icon" href="/meta/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/meta/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Hardik Verma" />
    <link rel="manifest" href="/meta/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/meta/og_image.png" />
    <meta property="og:url" content="https://github.com/Hardik-V" />
    <meta property="og:site_name" content="Hardik Verma" />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/meta/og_image.png" />

    <!-- The original bundled engine CSS & JS. Do not edit. -->
    <link rel="stylesheet" href="/scripts/index.css" />
    <!-- Portfolio-specific visual overrides. Loaded AFTER index.css so its
         rules win the cascade. Engine bindings are untouched. -->
    <link rel="stylesheet" href="/styles/overrides.css" />
    <link rel="stylesheet" href="/styles/grip-onboarding.css" />
    <script type="module" src="/scripts/main.js"></script>
  </head>
  <body>
    <slot />
    <script is:inline>
      document.addEventListener(
        "DOMContentLoaded",
        () => {
          const form = document.getElementById("footer-newsletter-form");
          const input = document.getElementById("footer-email-input");
          const message = document.getElementById("footer-newsletter-message");
          if (!form || !input) return;

          form.addEventListener(
            "submit",
            (event) => {
              event.preventDefault();
              event.stopImmediatePropagation();
              const email = input.value.trim();
              if (!email) return;
              if (message) {
                message.textContent = "Opening your mail app…";
              }
              window.location.href =
                "mailto:hardikverma2005@gmail.com?subject=Portfolio%20contact&body=" +
                encodeURIComponent("Hi Hardik,\n\nMy email: " + email + "\n\n");
            },
            true
          );
        },
        { once: true }
      );
    </script>
  </body>
</html>
